# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE / tooling
.vscode/
.idea/
.claude/

# Processed/intermediate data (regenerable from data/raw + src/)
# Raw MT5 snapshots ARE committed on purpose for reproducibility
# (see README) — only large regenerated intermediates are ignored.
data/processed/*
!data/processed/.gitkeep

# Streamlit
.streamlit/secrets.toml

# LaTeX build artifacts (paper/main.pdf is committed on purpose)
paper/_preview/
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
